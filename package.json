{
  "name": "farah-store",
  "version": "1.0.0",
  "description": "Farah Store POS System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "npx jest",
    "lint": "npx eslint .",
    "build": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.farahstore.pos",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "backend/**/*",
      "frontend/**/*",
      "main.js",
      "package.json"
    ]
  },
  "author": "Mahmoud-ELqalini",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "electron-log": "^5.4.4",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "jest-environment-jsdom": "^30.4.1"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/backend/tests/setup.js"
    ]
  }
}
